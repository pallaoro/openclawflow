{
  "id": "openclaw-flow",
  "name": "OpenClaw Flow",
  "description": "Agentic workflow engine for OpenClaw. AI-native, LLM-writable, Cloudflare-portable.",
  "version": "0.2.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": { "type": "string" },
      "defaultModel": { "type": "string" },
      "baseUrl": { "type": "string" },
      "gatewayUrl": { "type": "string" },
      "gatewayToken": { "type": "string" },
      "memoryDir": { "type": "string" },
      "stateDir": { "type": "string" },
      "maxNodeDurationMs": { "type": "number" }
    }
  },
  "uiHints": {
    "apiKey": { "label": "Anthropic API Key (fallback)", "sensitive": true, "help": "Only needed if gateway is unavailable" },
    "defaultModel": { "label": "Default AI Model", "placeholder": "smart" },
    "baseUrl": { "label": "Direct API Base URL", "placeholder": "https://api.anthropic.com" },
    "gatewayUrl": { "label": "Gateway URL", "help": "Auto-detected when running inside OpenClaw" },
    "gatewayToken": { "label": "Gateway Token", "sensitive": true, "help": "Auto-detected from OPENCLAW_GATEWAY_TOKEN" },
    "memoryDir": { "label": "Memory Directory" },
    "stateDir": { "label": "Flow State Directory" },
    "maxNodeDurationMs": { "label": "Node Timeout (ms)", "placeholder": "30000" }
  }
}
